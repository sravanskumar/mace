# ── Required ──────────────────────────────────────────────────────────
# AEMaaCS Author URL (local SDK: http://localhost:4502)
AEM_BASE_URL=http://localhost:4502

# AEM system user credentials
AEM_USERNAME=wknd-governance-service
AEM_PASSWORD=

# ── Optional — safe defaults shown ────────────────────────────────────
# Path to governance rules config (default: ./governance-rules.json)
GOVERNANCE_RULES_PATH=./governance-rules.json

# HTTP request timeout in milliseconds (default: 30000)
AEM_TIMEOUT_MS=30000

# Max pages per violation scan — safety cap (default: 500)
AEM_MAX_PAGES=500

# Max depth to traverse jcr:content tree (default: 10)
TRAVERSAL_DEPTH=10
